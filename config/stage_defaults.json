{
  "runtime": {
    "seed": 0,
    "device": "auto",
    "baseline_family": "baseline_candidate",
    "round_budget_label": "primary_iteration_mid_budget",
    "formal_execution_budget": 3500,
    "max_rounds_per_active_subflow": 1
  },
  "stage_gates": {
    "promotion_ratio_limit": 1.05,
    "require_sanity_checks": true,
    "allow_downstream_on_review_pass": true
  },
  "analysis": {
    "priority_targets": [
      "highest-risk artifacts",
      "boundary cases",
      "recent regressions"
    ],
    "comparison_metrics": [
      "primary_quality_metric",
      "secondary_quality_metric",
      "stability_metric",
      "regression_count"
    ],
    "minimum_required_artifacts": 3
  },
  "smoke_check": {
    "must_detect": [
      "broken execution",
      "clearly invalid outputs",
      "missing required artifacts"
    ]
  },
  "formal_execution": {
    "required_outputs": [
      "stage_summary.json",
      "diagnostics.json",
      "artifact_manifest.json"
    ]
  },
  "retention": {
    "snapshot_on_round_completion": true,
    "retain_latest_stage_runs": 3,
    "retire_superseded_noise": true
  }
}
