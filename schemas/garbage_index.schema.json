{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GarbageIndex",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_name",
    "records"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "archived_paths",
          "reason",
          "retention_reason",
          "can_restore",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "archived_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": "string"
          },
          "retention_reason": {
            "type": "string"
          },
          "replacement_ref": {
            "type": "string"
          },
          "derived_lesson_ref": {
            "type": "string"
          },
          "superseded_by": {
            "type": "string"
          },
          "can_restore": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
