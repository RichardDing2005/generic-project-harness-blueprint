{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GarbageIndex",
  "type": "object",
  "required": [
    "schema_version",
    "project_name",
    "records"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "project_name": {
      "type": "string"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "archived_paths",
          "reason",
          "replacement_ref",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "archived_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": "string"
          },
          "replacement_ref": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          }
        }
      }
    }
  }
}
