{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryIndex",
  "type": "object",
  "required": [
    "schema_version",
    "project_name",
    "active_snapshot",
    "recent_events",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "project_name": {
      "type": "string"
    },
    "active_snapshot": {
      "type": "string"
    },
    "recent_events": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "garbage_policy_version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
